# ==============================================================================
#  TOUR DE CONTRÔLE : CONFIGURATION AVANCÉE DU NOYAU ANDROID (AVEC SUSFS)
# ==============================================================================

# 1. PARAMÈTRES DU CODE SOURCE DU NOYAU
# ------------------------------------------------------------------------------
KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_motorola_sm8250.git
KERNEL_SOURCE_BRANCH=lineage-23.0
KERNEL_CONFIG=vendor/sm8250-perf_defconfig
KERNEL_IMAGE_NAME=Image.gz
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=true

# 2. SELECTION DU COMPILATEUR AVANCÉ (CUSTOM TOOLCHAIN)
# ------------------------------------------------------------------------------
# Active "true" pour utiliser un compilateur optimisé de la communauté (recommandé)
USE_CUSTOM_CLANG=true

# Liens vers des Clang hautement optimisés (décommente celui de ton choix)
# Proton Clang (Excellent pour les noyaux 4.14 / 4.19)
CUSTOM_CLANG_SOURCE=https://github.com/kdrag0n/proton-clang.git
CUSTOM_CLANG_BRANCH=master

# Alternative : ZyC Clang (Idéal pour les optimisations LLVM récentes)
# CUSTOM_CLANG_SOURCE=https://github.com/ZyCromerZ/Clang.git
# CUSTOM_CLANG_BRANCH=14

# Forçage des outils LLVM pour interdire l'utilisation d'outils obsolètes du serveur
# Évite le fameux bug "objcopy: Unable to recognise the format" sur le VDSO
USE_LLVM_ARM64_TOOLS=true
LLVM_OBJCOPY=llvm-objcopy
LLVM_STRIP=llvm-strip

# 3. COMPILATEURS SECONDAIRES GCC (COMPATIBILITÉ NOYAUX ANCIENS)
# ------------------------------------------------------------------------------
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# 4. CONFIGURATION DE KERNELSU
# ------------------------------------------------------------------------------
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
# Mode d'installation de KernelSU : "legacy" (hooks fs/open.c) ou "gki" (si supporté)
KSU_INSTALL_METHOD=legacy

# 5. CONFIGURATION DE SUSFS (ANTI-DÉTECTION AVANCÉE)
# ------------------------------------------------------------------------------
# SusFS permet de cacher KernelSU, les fichiers overlay et l'état du noyau aux banques
ENABLE_SUSFS=false
SUSFS_VERSION=v1.5.1

# URL du dépôt miroir public des patchs SusFS
SUSFS_PATCH_SOURCE=https://github.com/Gaurav7557/susfs4ksu.git
SUSFS_PATCH_BRANCH=main

# 6. OPTIMISATIONS ET SÉCURITÉS DE COMPILATION
# ------------------------------------------------------------------------------
ENABLE_CCACHE=true
DISABLE_LTO=true                    # Mettre à true si le serveur manque de RAM (évite le crash à 90%)
DISABLE_CC_WERROR=true              # Ignore les avertissements simples pour éviter de stopper le build
ADD_KPROBES_CONFIG=true             # Force l'activation de Kprobes si nécessaire
ADD_OVERLAYFS_CONFIG=true           # Indispensable pour l'écriture de modules magisk/ksu

# 7. EMBALLAGE ET LIVRAISON (ANYKERNEL3)
# ------------------------------------------------------------------------------
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=
USE_CUSTOM_ANYKERNEL3=false
CUSTOM_ANYKERNEL3_SOURCE=https://github.com/osm0sis/AnyKernel3.git
CUSTOM_ANYKERNEL3_BRANCH=master

# Nettoyage des paquets inutiles sur le serveur GitHub pour libérer 30 Go d'espace
REMOVE_UNUSED_PACKAGES=true
